# ReelGrab – Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Server ────────────────────────────────────────────────
NODE_ENV=development        # development | production
PORT=3001                   # Backend port

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_URL=https://your-vercel-url.vercel.app
# Add your frontend URL here for CORS (e.g. https://reelgrab.app)

# ─── Admin Panel ───────────────────────────────────────────
ADMIN_API_KEY=change_this_to_a_long_random_secret_key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Email (for Contact Form) ──────────────────────────────
# Uncomment if using Nodemailer
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_app_password   # Gmail App Password (not account password)
# ADMIN_EMAIL=admin@reelgrab.app

# ─── Optional: RapidAPI Instagram Downloader ───────────────
# Use this instead of yt-dlp if you prefer a managed API
# RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Optional: Analytics ──────────────────────────────────
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
